10  REM ========================
20  REM   APPLE ][ NUMBER RACE
30  REM ========================
40  DIM P(5)
50  FL = 36: REM FINISH LINE COL
100  REM ---- TITLE SCREEN ----
110  HOME : TEXT
120  VTAB 4: HTAB 9
130  PRINT "**********************"
140  VTAB 5: HTAB 9
150  PRINT "*                    *"
160  VTAB 6: HTAB 9
170  PRINT "*  APPLE ][ RACES!   *"
180  VTAB 7: HTAB 9
190  PRINT "*                    *"
200  VTAB 8: HTAB 9
210  PRINT "**********************"
220  VTAB 11: HTAB 6
230  PRINT "5 NUMBERS RACE TO THE"
240  VTAB 12: HTAB 9
250  PRINT "FINISH LINE!"
260  VTAB 15: HTAB 4
270  PRINT "RACERS:  1  2  3  4  5"
280  VTAB 18: HTAB 5
290  PRINT "PRESS ANY KEY TO START"
300  GET A$
400  REM ---- SET UP RACE ----
410  HOME
420  FOR I = 1 TO 5:P(I) = 1: NEXT I
430  VTAB 1: HTAB 12
440  PRINT "APPLE ][ RACES"
450  REM DRAW FINISH LINE LABEL
460  VTAB 2: HTAB FL - 2
470  PRINT "FINISH"
480  REM DRAW FINISH LINE POSTS
490  FOR R = 3 TO 19
500  VTAB R: HTAB FL: PRINT "|"
510  NEXT R
520  REM DRAW LANE SEPARATORS
530  FOR I = 1 TO 5
540  R = I * 3
550  VTAB R: HTAB 1
560  FOR C = 1 TO FL - 1
570  PRINT "-";
580  NEXT C
590  NEXT I
600  VTAB 18: HTAB 1
610  FOR C = 1 TO FL - 1
620  PRINT "-";
630  NEXT C
640  REM DRAW STARTING POSITIONS
650  FOR I = 1 TO 5
660  R = I * 3 + 1
670  VTAB R: HTAB 1
680  PRINT CHR$(48 + I);
690  NEXT I
700  VTAB 21: HTAB 8
710  PRINT "AND THEY'RE OFF!"
720  VTAB 23: HTAB 8
730  PRINT "R = RESTART"
800  REM ---- MAIN RACE LOOP ----
810  FOR I = 1 TO 5
820  IF RND (1) > 0.55 THEN GOTO 900
830  GOTO 960
900  REM -- MOVE RACER I --
910  R = I * 3 + 1
920  VTAB R: HTAB P(I)
930  PRINT " ";
940  P(I) = P(I) + 1
950  VTAB R: HTAB P(I)
951  PRINT CHR$(48 + I);
955  IF P(I) >= FL THEN GOTO 1100
960  NEXT I
970  REM CHECK FOR R KEY
980  K = PEEK ( - 16384)
990  IF K > 127 THEN POKE  - 16368,0
991  IF K = 210 THEN GOTO 400
995  REM DELAY LOOP
1000  FOR D = 1 TO 40: NEXT D
1010  GOTO 800
1100  REM ---- WE HAVE A WINNER ----
1110  W = I
1120  VTAB 21: HTAB 1
1130  PRINT "                                       "
1140  VTAB 21: HTAB 4
1150  PRINT "** RACER ";CHR$(48 + W);" WINS THE RACE! **"
1160  VTAB 23: HTAB 1
1170  PRINT "                                       "
1180  VTAB 23: HTAB 4
1190  PRINT "PRESS ANY KEY TO PLAY"
1200  REM FLASH THE WINNER
1210  FOR J = 1 TO 8
1220  R = W * 3 + 1
1230  VTAB R: HTAB P(W)
1240  PRINT "*";
1250  FOR D = 1 TO 80: NEXT D
1260  VTAB R: HTAB P(W)
1270  PRINT CHR$(48 + W);
1280  FOR D = 1 TO 80: NEXT D
1290  NEXT J
1300  GET A$
1310  GOTO 100
